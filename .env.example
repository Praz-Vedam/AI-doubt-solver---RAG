# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/video_knowledge_chatbot?schema=public"

# LLM provider: ollama | openai | openrouter
LLM_PROVIDER="ollama"

# Ollama (local default; use an ngrok URL only when tunneling a remote instance)
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_API_KEY="ollama"
LLM_MODEL="qwen2.5:7b"

# Optional per-role LLM overrides (both fall back to LLM_PROVIDER / LLM_MODEL).
# index = knowledgebase indexing (open-source LLM), chat = query-time (cloud LLM API).
# LLM_INDEX_PROVIDER="ollama"
# LLM_INDEX_MODEL="gemma3:27b"
# LLM_CHAT_PROVIDER="openrouter"
# LLM_CHAT_MODEL="anthropic/claude-3.5-haiku"

# Top-k page-index nodes injected into chat context
RAG_TOP_K=5

# OpenAI (optional fallback for Whisper)
OPENAI_API_KEY=""

# OpenRouter (optional alternative LLM provider)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Whisper: local | openai | hosted
WHISPER_PROVIDER="hosted"
WHISPER_BASE_URL="https://drastic-churn-scarcity.ngrok-free.dev"
# WHISPER_TRANSCRIBE_PATH="/transcribe"
# WHISPER_STATUS_PATH="/status"
# WHISPER_POLL_INTERVAL_MS=3000
# WHISPER_JOB_TIMEOUT_MS=3600000
WHISPER_MODEL="Xenova/whisper-small.en"
OPENAI_WHISPER_MODEL="whisper-1"

# Long-audio chunking (openai/hosted providers): target chunk length in seconds and
# how many chunks to transcribe in parallel. Defaults: 600s chunks;
# concurrency 4 (openai) or 1 (hosted — avoids overloading a remote GPU box).
# WHISPER_CHUNK_SECONDS=600
# WHISPER_CONCURRENCY=1
# WHISPER_MAX_FILE_BYTES=25165824

# Upload settings
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR="uploads/videos"
